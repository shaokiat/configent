---
interface Props {
  title: string;
  description: string;
  configSnippet?: string;
  demoUrl?: string;
  tags?: string[];
}

const {
  title,
  description,
  configSnippet,
  demoUrl = '#',
  tags = [],
} = Astro.props;
---

<div class="demo-card">
  <div class="demo-card-header">
    <div class="demo-card-meta">
      <div class="demo-tags">
        {tags.map(t => <span class="tag">{t}</span>)}
      </div>
      <h3 class="demo-title">{title}</h3>
      <p class="demo-desc">{description}</p>
    </div>
  </div>

  {configSnippet && (
    <div class="demo-config">
      <div class="config-label">Config used</div>
      <pre class="config-pre"><code set:html={configSnippet} /></pre>
    </div>
  )}

  <div class="demo-card-footer">
    <a href={demoUrl} class="demo-btn" target="_blank" rel="noopener noreferrer">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <polygon points="5 3 19 12 5 21 5 3"/>
      </svg>
      Launch demo
    </a>
  </div>
</div>

<style>
  .demo-card {
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    background: var(--bg-surface);
    overflow: hidden;
    transition: border-color 0.2s;
  }
  .demo-card:hover { border-color: var(--accent); }

  .demo-card-header { padding: 1.5rem 1.5rem 0; }

  .demo-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.375rem;
    margin-bottom: 0.75rem;
  }

  .tag {
    display: inline-block;
    padding: 0.2rem 0.6rem;
    background: var(--accent-subtle);
    border: 1px solid rgba(99,102,241,0.2);
    border-radius: 100px;
    font-size: 0.7rem;
    color: var(--accent);
    font-weight: 500;
    letter-spacing: 0.03em;
  }

  .demo-title {
    font-size: 1.125rem;
    color: var(--text);
    margin-bottom: 0.5rem;
  }

  .demo-desc {
    font-size: 0.875rem;
    color: var(--text-muted);
    line-height: 1.6;
    margin-bottom: 1rem;
  }

  .demo-config {
    margin: 0 1.5rem;
    border: 1px solid var(--border);
    border-radius: var(--radius);
    overflow: hidden;
  }

  .config-label {
    padding: 0.4rem 1rem;
    background: var(--bg-elevated);
    border-bottom: 1px solid var(--border);
    font-size: 0.7rem;
    color: var(--text-muted);
    font-family: var(--font-mono);
    letter-spacing: 0.05em;
    text-transform: uppercase;
  }

  .config-pre {
    margin: 0;
    padding: 1rem;
    background: transparent;
    border: none;
    border-radius: 0;
    font-size: 0.8rem;
    line-height: 1.7;
    overflow-x: auto;
  }

  .demo-card-footer {
    padding: 1.25rem 1.5rem;
  }

  .demo-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.625rem 1.25rem;
    background: var(--accent);
    color: #fff;
    border-radius: var(--radius);
    font-size: 0.875rem;
    font-weight: 500;
    transition: background 0.15s;
    text-decoration: none;
  }
  .demo-btn:hover { background: var(--accent-dim); text-decoration: none; }
</style>
