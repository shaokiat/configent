---
// Architecture flow diagram — no external dependencies, pure SVG + CSS
---

<div class="diagram-wrap">
  <svg
    class="arch-svg"
    viewBox="0 0 960 520"
    xmlns="http://www.w3.org/2000/svg"
    role="img"
    aria-label="Configent architecture: config file feeds into the orchestration layer which initialises RAG and tools, runs the agent loop, and produces structured output"
  >
    <defs>
      <!-- Arrow marker -->
      <marker id="arrow" markerWidth="8" markerHeight="6" refX="7" refY="3" orient="auto">
        <polygon points="0 0, 8 3, 0 6" fill="#6366f1"/>
      </marker>
      <marker id="arrow-dim" markerWidth="8" markerHeight="6" refX="7" refY="3" orient="auto">
        <polygon points="0 0, 8 3, 0 6" fill="#4a4a6a"/>
      </marker>

      <!-- Glow filter -->
      <filter id="glow" x="-20%" y="-20%" width="140%" height="140%">
        <feGaussianBlur stdDeviation="3" result="blur"/>
        <feMerge><feMergeNode in="blur"/><feMergeNode in="SourceGraphic"/></feMerge>
      </filter>
    </defs>

    <!-- ── Config file (left) ─────────────────────────────────── -->
    <g class="node node-config" transform="translate(30, 190)">
      <rect width="140" height="140" rx="10" fill="#111118" stroke="#6366f1" stroke-width="1.5"/>
      <!-- YAML icon lines -->
      <text x="70" y="38" text-anchor="middle" font-family="monospace" font-size="10" fill="#7dd3fc">client_id: acme</text>
      <text x="70" y="54" text-anchor="middle" font-family="monospace" font-size="10" fill="#4a4a6a">knowledge_base:</text>
      <text x="70" y="70" text-anchor="middle" font-family="monospace" font-size="10" fill="#4a4a6a">  sources: [...]</text>
      <text x="70" y="86" text-anchor="middle" font-family="monospace" font-size="10" fill="#4a4a6a">agent:</text>
      <text x="70" y="102" text-anchor="middle" font-family="monospace" font-size="10" fill="#4a4a6a">  model: claude</text>
      <text x="70" y="118" text-anchor="middle" font-family="monospace" font-size="10" fill="#4a4a6a">tools: [...]</text>
      <text x="70" y="136" text-anchor="middle" font-family="monospace" font-size="11" fill="#6366f1" font-weight="600">config.yaml</text>
    </g>

    <!-- Arrow: config → engine -->
    <line x1="170" y1="260" x2="210" y2="260" stroke="#6366f1" stroke-width="1.5" marker-end="url(#arrow)"/>

    <!-- ── Engine outer box ───────────────────────────────────── -->
    <rect x="215" y="30" width="580" height="460" rx="12" fill="#0d0d16" stroke="#252535" stroke-width="1.5" stroke-dasharray="4 3"/>
    <text x="505" y="58" text-anchor="middle" font-family="system-ui, sans-serif" font-size="11" fill="#4a4a6a" letter-spacing="0.08em">CONFIGENT ENGINE</text>

    <!-- ── Orchestration layer ────────────────────────────────── -->
    <rect x="235" y="70" width="540" height="100" rx="8" fill="#111118" stroke="#252535" stroke-width="1"/>
    <text x="505" y="95" text-anchor="middle" font-family="system-ui, sans-serif" font-size="12" fill="#8888aa" font-weight="500">Orchestration Layer</text>

    <!-- Tool Registry box -->
    <rect x="255" y="105" width="220" height="50" rx="6" fill="#1a1a26" stroke="#252535"/>
    <text x="365" y="125" text-anchor="middle" font-family="monospace" font-size="11" fill="#fbbf24">Tool Registry</text>
    <text x="365" y="143" text-anchor="middle" font-family="system-ui, sans-serif" font-size="10" fill="#4a4a6a">register + validate tools from config</text>

    <!-- RAG Setup box -->
    <rect x="495" y="105" width="260" height="50" rx="6" fill="#1a1a26" stroke="#252535"/>
    <text x="625" y="125" text-anchor="middle" font-family="monospace" font-size="11" fill="#7dd3fc">RAG Pipeline</text>
    <text x="625" y="143" text-anchor="middle" font-family="system-ui, sans-serif" font-size="10" fill="#4a4a6a">embed docs → pgvector → retrieval</text>

    <!-- Arrow: orchestration → agent loop -->
    <line x1="505" y1="170" x2="505" y2="215" stroke="#252535" stroke-width="1.5" marker-end="url(#arrow-dim)"/>

    <!-- ── Agent Loop ──────────────────────────────────────────── -->
    <rect x="285" y="220" width="440" height="180" rx="8" fill="#111118" stroke="#6366f1" stroke-width="1.5" filter="url(#glow)"/>
    <text x="505" y="248" text-anchor="middle" font-family="system-ui, sans-serif" font-size="12" fill="#8888aa" font-weight="500">Agent Loop</text>

    <!-- Claude LLM -->
    <rect x="305" y="260" width="180" height="120" rx="6" fill="#1a1a26" stroke="#6366f1" stroke-width="1"/>
    <text x="395" y="285" text-anchor="middle" font-family="monospace" font-size="12" fill="#e2e2f0" font-weight="600">Claude LLM</text>
    <text x="395" y="303" text-anchor="middle" font-family="system-ui, sans-serif" font-size="10" fill="#6366f1">claude-sonnet-4-6</text>
    <text x="395" y="323" text-anchor="middle" font-family="system-ui, sans-serif" font-size="10" fill="#4a4a6a">↑ tool results</text>
    <text x="395" y="339" text-anchor="middle" font-family="system-ui, sans-serif" font-size="10" fill="#4a4a6a">↓ tool calls</text>
    <text x="395" y="358" text-anchor="middle" font-family="system-ui, sans-serif" font-size="10" fill="#4a4a6a">streaming via SSE</text>
    <text x="395" y="374" text-anchor="middle" font-family="system-ui, sans-serif" font-size="10" fill="#4a4a6a">prompt cache enabled</text>

    <!-- Tools panel -->
    <rect x="505" y="260" width="200" height="120" rx="6" fill="#1a1a26" stroke="#252535"/>
    <text x="605" y="280" text-anchor="middle" font-family="monospace" font-size="11" fill="#86efac">Active Tools</text>
    <text x="605" y="300" text-anchor="middle" font-family="monospace" font-size="10" fill="#4a4a6a">search_knowledge_base</text>
    <text x="605" y="316" text-anchor="middle" font-family="monospace" font-size="10" fill="#4a4a6a">get_pricing</text>
    <text x="605" y="332" text-anchor="middle" font-family="monospace" font-size="10" fill="#4a4a6a">create_ticket</text>
    <text x="605" y="352" text-anchor="middle" font-family="system-ui, sans-serif" font-size="9" fill="#3a3a5a">← defined in config.yaml</text>
    <text x="605" y="370" text-anchor="middle" font-family="system-ui, sans-serif" font-size="9" fill="#3a3a5a">← no code changes</text>

    <!-- Bidirectional arrows between LLM and tools -->
    <line x1="490" y1="300" x2="506" y2="300" stroke="#4a4a6a" stroke-width="1" marker-end="url(#arrow-dim)"/>
    <line x1="506" y1="320" x2="490" y2="320" stroke="#4a4a6a" stroke-width="1" marker-end="url(#arrow-dim)"/>

    <!-- Arrow: agent loop → output -->
    <line x1="505" y1="400" x2="505" y2="448" stroke="#6366f1" stroke-width="1.5" marker-end="url(#arrow)"/>

    <!-- ── Output ──────────────────────────────────────────────── -->
    <rect x="330" y="450" width="350" height="24" rx="6" fill="#1a2620" stroke="#34d399" stroke-width="1"/>
    <text x="505" y="467" text-anchor="middle" font-family="system-ui, sans-serif" font-size="11" fill="#34d399" font-weight="500">
      Streamed response · Inline citations · Structured tool output
    </text>

    <!-- ── Documents input (top right) ───────────────────────── -->
    <g transform="translate(810, 90)">
      <rect width="120" height="80" rx="8" fill="#111118" stroke="#252535" stroke-width="1"/>
      <text x="60" y="28" text-anchor="middle" font-family="system-ui, sans-serif" font-size="10" fill="#8888aa">Input Documents</text>
      <text x="60" y="46" text-anchor="middle" font-family="monospace" font-size="10" fill="#4a4a6a">PDF / URL / text</text>
      <text x="60" y="62" text-anchor="middle" font-family="monospace" font-size="10" fill="#4a4a6a">embed on startup</text>
      <text x="60" y="76" text-anchor="middle" font-family="system-ui, sans-serif" font-size="10" fill="#4a4a6a">pgvector index</text>
    </g>

    <!-- Arrow: docs → RAG -->
    <line x1="810" y1="130" x2="758" y2="130" stroke="#252535" stroke-width="1.5" marker-end="url(#arrow-dim)"/>

    <!-- Labels -->
    <text x="30" y="182" font-family="system-ui, sans-serif" font-size="10" fill="#4a4a6a">1. Author config</text>
    <text x="215" y="22" font-family="system-ui, sans-serif" font-size="10" fill="#4a4a6a">2. Configent initialises pipeline</text>
    <text x="215" y="215" font-family="system-ui, sans-serif" font-size="10" fill="#6366f1">3. Queries run through agent loop</text>
    <text x="330" y="495" font-family="system-ui, sans-serif" font-size="10" fill="#4a4a6a" text-anchor="middle">4. Response delivered</text>
    <text x="505" y="495" font-family="system-ui, sans-serif" font-size="10" fill="#4a4a6a" text-anchor="middle"></text>
  </svg>
</div>

<style>
  .diagram-wrap {
    width: 100%;
    background: var(--bg);
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    overflow: hidden;
    padding: 1.5rem;
  }

  .arch-svg {
    width: 100%;
    height: auto;
    display: block;
  }

  .node-config rect {
    transition: stroke 0.2s;
  }
  .node-config:hover rect {
    stroke: #818cf8;
  }
</style>
