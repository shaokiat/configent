---
import { getCollection } from 'astro:content';
import BaseLayout from './BaseLayout.astro';

interface Props {
  title: string;
  description?: string;
}

const { title, description } = Astro.props;

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const currentPath = Astro.url.pathname;

const allDocs = await getCollection('docs');
const sorted = allDocs
  .filter(doc => doc.data.group)
  .sort((a, b) => (a.data.order ?? 99) - (b.data.order ?? 99));

// Group docs, ordering groups by the lowest `order` value in each group
const groupMap = new Map<string, { minOrder: number; links: { href: string; label: string }[] }>();
for (const doc of sorted) {
  const g = doc.data.group!;
  if (!groupMap.has(g)) groupMap.set(g, { minOrder: doc.data.order ?? 99, links: [] });
  groupMap.get(g)!.links.push({ href: `${base}/docs/${doc.slug}`, label: doc.data.title });
}
const sidebarLinks = [...groupMap.entries()]
  .sort((a, b) => a[1].minOrder - b[1].minOrder)
  .map(([group, { links }]) => ({ group, links }));

function isActive(href: string) {
  return currentPath === href || currentPath === href + '/';
}
---

<BaseLayout title={title} description={description}>
  <div class="docs-layout container">
    <aside class="sidebar" aria-label="Documentation navigation">
      <nav>
        {sidebarLinks.map(group => (
          <div class="sidebar-group">
            <div class="sidebar-group-label">{group.group}</div>
            {group.links.map(link => (
              <a
                href={link.href}
                class:list={['sidebar-link', { active: isActive(link.href) }]}
              >
                {link.label}
              </a>
            ))}
          </div>
        ))}
      </nav>
    </aside>

    <article class="docs-content">
      <slot />
    </article>
  </div>
</BaseLayout>

<style>
  .docs-layout {
    display: grid;
    grid-template-columns: var(--sidebar-width) 1fr;
    gap: 3rem;
    padding-top: 3rem;
    padding-bottom: 3rem;
    align-items: start;
  }

  .sidebar {
    position: sticky;
    top: calc(var(--nav-height) + 1.5rem);
    max-height: calc(100vh - var(--nav-height) - 3rem);
    overflow-y: auto;
  }

  .sidebar-group {
    margin-bottom: 1.25rem;
  }

  .sidebar-group-label {
    font-size: 0.7rem;
    font-weight: 600;
    color: var(--text-faint);
    letter-spacing: 0.1em;
    text-transform: uppercase;
    padding: 0 0.75rem;
    margin-bottom: 0.2rem;
  }

  .sidebar-link {
    display: block;
    padding: 0.25rem 0.75rem;
    border-radius: var(--radius-sm);
    font-size: 0.875rem;
    color: var(--text-muted);
    transition: color 0.15s, background 0.15s;
    text-decoration: none;
  }
  .sidebar-link:hover {
    color: var(--text);
    background: var(--bg-elevated);
    text-decoration: none;
  }
  .sidebar-link.active {
    color: var(--accent);
    background: var(--accent-subtle);
  }

  /* ── Docs content typography ──────────────────────────────────── */
  .docs-content {
    max-width: var(--content-max);
    min-width: 0;
  }

  .docs-content :global(h1) {
    font-size: 2rem;
    margin-bottom: 0.5rem;
    color: var(--text);
  }

  .docs-content :global(h2) {
    margin-top: 3rem;
    margin-bottom: 0.75rem;
    padding-bottom: 0.5rem;
    border-bottom: 1px solid var(--border);
    color: var(--text);
  }

  .docs-content :global(h3) {
    margin-top: 2rem;
    color: var(--text);
  }

  .docs-content :global(p) {
    line-height: 1.75;
    color: var(--text-muted);
  }

  .docs-content :global(ul),
  .docs-content :global(ol) {
    padding-left: 1.5rem;
    color: var(--text-muted);
    line-height: 1.75;
    margin-bottom: 1rem;
  }

  .docs-content :global(li) { margin-bottom: 0.25rem; }

  .docs-content :global(table) {
    width: 100%;
    border-collapse: collapse;
    font-size: 0.875rem;
    margin: 1.5rem 0;
  }

  .docs-content :global(th) {
    text-align: left;
    padding: 0.625rem 1rem;
    background: var(--bg-elevated);
    border: 1px solid var(--border);
    color: var(--text);
    font-weight: 500;
    font-size: 0.8rem;
  }

  .docs-content :global(td) {
    padding: 0.625rem 1rem;
    border: 1px solid var(--border);
    color: var(--text-muted);
    vertical-align: top;
  }

  .docs-content :global(tr:hover td) {
    background: var(--bg-surface);
  }

  .docs-content :global(blockquote) {
    border-left: 3px solid var(--accent);
    padding: 0.75rem 1.25rem;
    margin: 1.5rem 0;
    background: var(--accent-subtle);
    border-radius: 0 var(--radius) var(--radius) 0;
    color: var(--text-muted);
    font-size: 0.9375rem;
  }

  .docs-content :global(.lead) {
    font-size: 1.125rem;
    color: var(--text-muted);
    margin-bottom: 2rem;
    line-height: 1.7;
  }

  @media (max-width: 768px) {
    .docs-layout {
      grid-template-columns: 1fr;
    }
    .sidebar {
      position: static;
      border-bottom: 1px solid var(--border);
      padding-bottom: 1.5rem;
      margin-bottom: 1.5rem;
    }
  }
</style>
