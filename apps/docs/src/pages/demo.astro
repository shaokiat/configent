---
import BaseLayout from '@/layouts/BaseLayout.astro';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');

const DEMO_URL = 'https://configent-demo.vercel.app'; // placeholder

const demoConfig = `client_id: acme-fab
name: "Acme Fab Equipment"

branding:
  logo: assets/acme-fab/logo.svg
  primary_color: "#1B4F8A"
  assistant_name: AcmeAssist

corpus:
  source: corpora/acme-fab/
  chunking:
    chunk_size: 800
    overlap: 100

agent:
  model: claude-sonnet-4-6
  system_prompt_file: prompts/acme-fab.md
  max_tokens: 4096
  effort: medium
  tools:
    - search_docs
    - get_document
    - pricing_lookup

evals:
  golden_set: evals/acme-fab/golden.jsonl
  judge_model: claude-sonnet-4-6

limits:
  rate_limit_per_minute: 20
  daily_budget_usd: 2.00`;
---

<BaseLayout
  title="Demo"
  description="Try the Configent live demo — a fully functional RAG assistant running on a single config file."
>

  <div class="page container">
    <div class="page-header">
      <div class="page-label">Live Demo</div>
      <h1>See Configent in action</h1>
      <p class="lead">
        The demo below is a live deployment of Configent with a single
        <code>config.yaml</code>. The assistant answers questions about its own
        documentation — no custom code, only the config shown below.
      </p>
    </div>

    <!-- ── Demo card ────────────────────────────────────────────── -->
    <div class="demo-hero">
      <div class="demo-left">
        <div class="demo-meta">
          <div class="meta-row">
            <span class="meta-key">Client ID</span>
            <code class="meta-val">acme-fab</code>
          </div>
          <div class="meta-row">
            <span class="meta-key">Model</span>
            <code class="meta-val">claude-sonnet-4-6</code>
          </div>
          <div class="meta-row">
            <span class="meta-key">Corpus</span>
            <code class="meta-val">corpora/acme-fab/ · PDFs + MD</code>
          </div>
          <div class="meta-row">
            <span class="meta-key">Tools</span>
            <code class="meta-val">search_docs, get_document, pricing_lookup</code>
          </div>
          <div class="meta-row">
            <span class="meta-key">Embeddings</span>
            <code class="meta-val">Voyage AI voyage-3</code>
          </div>
          <div class="meta-row">
            <span class="meta-key">Prompt caching</span>
            <code class="meta-val green">always on</code>
          </div>
          <div class="meta-row">
            <span class="meta-key">Custom code</span>
            <code class="meta-val dim">none</code>
          </div>
        </div>

        <div class="what-to-try">
          <div class="wtt-label">Things to try</div>
          <ul>
            <li>"How does the agent loop work?"</li>
            <li>"Show me a config for a support bot"</li>
            <li>"What tools can I enable?"</li>
            <li>"How is multi-tenancy handled?"</li>
          </ul>
        </div>

        <a href={DEMO_URL} class="launch-btn" target="_blank" rel="noopener noreferrer">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <polygon points="5 3 19 12 5 21 5 3"/>
          </svg>
          Launch demo
          <span class="launch-hint">opens in new tab</span>
        </a>
      </div>

      <div class="demo-right">
        <div class="config-panel">
          <div class="config-panel-header">
            <span class="dot r"></span>
            <span class="dot a"></span>
            <span class="dot g"></span>
            <span class="config-panel-filename">config.yaml</span>
            <span class="config-panel-badge">full config for this demo</span>
          </div>
          <pre class="config-panel-body"><code>{demoConfig}</code></pre>
        </div>
      </div>
    </div>

    <!-- ── What the demo shows ─────────────────────────────────── -->
    <section class="section">
      <h2>What the demo shows</h2>
      <div class="show-grid">
        <div class="show-item">
          <div class="show-icon">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
              <path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/>
            </svg>
          </div>
          <div>
            <h4>Streaming responses</h4>
            <p>Text arrives token by token over SSE. No waiting for the full response.</p>
          </div>
        </div>
        <div class="show-item">
          <div class="show-icon">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
              <path d="M9 19c-5 1.5-5-2.5-7-3m14 6v-3.87a3.37 3.37 0 0 0-.94-2.61c3.14-.35 6.44-1.54 6.44-7A5.44 5.44 0 0 0 20 4.77 5.07 5.07 0 0 0 19.91 1S18.73.65 16 2.48a13.38 13.38 0 0 0-7 0C6.27.65 5.09 1 5.09 1A5.07 5.07 0 0 0 5 4.77a5.44 5.44 0 0 0-1.5 3.78c0 5.42 3.3 6.61 6.44 7A3.37 3.37 0 0 0 9 18.13V22"/>
            </svg>
          </div>
          <div>
            <h4>Live citations</h4>
            <p>Every factual claim links back to the source PDF chunk it was retrieved from.</p>
          </div>
        </div>
        <div class="show-item">
          <div class="show-icon">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
              <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/>
              <polyline points="14 2 14 8 20 8"/>
            </svg>
          </div>
          <div>
            <h4>Multi-turn context</h4>
            <p>The assistant maintains conversation history within a session. Follow-up questions work naturally.</p>
          </div>
        </div>
        <div class="show-item">
          <div class="show-icon">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
              <polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/>
            </svg>
          </div>
          <div>
            <h4>Tool calling</h4>
            <p>The knowledge base search tool is invoked automatically when needed, and the call is visible in the UI.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- ── Deploy your own ──────────────────────────────────────── -->
    <section class="section deploy-section">
      <div class="deploy-inner">
        <div>
          <h2>Deploy your own instance</h2>
          <p>
            Clone the repo, write a config for your use case, and you have the same
            assistant — pointed at your own documents.
          </p>
        </div>
        <a href={`${base}/docs/getting-started`} class="btn-outline">
          Quickstart guide
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M5 12h14M12 5l7 7-7 7"/>
          </svg>
        </a>
      </div>
    </section>
  </div>

</BaseLayout>

<style>
  .page {
    padding-top: 4rem;
    padding-bottom: 4rem;
  }

  .page-header {
    max-width: 64ch;
    margin-bottom: 3rem;
  }

  .page-label {
    font-size: 0.75rem;
    font-weight: 600;
    color: var(--accent);
    letter-spacing: 0.1em;
    text-transform: uppercase;
    margin-bottom: 0.75rem;
  }

  .page-header h1 { margin-bottom: 1rem; }

  .lead {
    font-size: 1.0625rem;
    color: var(--text-muted);
    line-height: 1.7;
    margin: 0;
  }

  /* ── Demo hero ────────────────────────────────────────────────── */
  .demo-hero {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 2rem;
    margin-bottom: 4rem;
  }

  .demo-left {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .demo-meta {
    background: var(--bg-surface);
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    padding: 1.25rem;
  }

  .meta-row {
    display: flex;
    align-items: baseline;
    gap: 0.75rem;
    padding: 0.5rem 0;
    border-bottom: 1px solid var(--border);
    font-size: 0.875rem;
  }
  .meta-row:last-child { border-bottom: none; }

  .meta-key {
    color: var(--text-muted);
    width: 130px;
    flex-shrink: 0;
  }

  .meta-val {
    font-family: var(--font-mono);
    font-size: 0.8rem;
    color: var(--text);
    background: var(--bg-elevated);
    padding: 0.1rem 0.4rem;
    border-radius: var(--radius-sm);
    border: 1px solid var(--border);
  }
  .meta-val.green { color: var(--green); border-color: rgba(52,211,153,0.2); background: rgba(52,211,153,0.06); }
  .meta-val.dim   { color: var(--text-faint); }

  .what-to-try {
    background: var(--bg-surface);
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    padding: 1.25rem;
  }

  .wtt-label {
    font-size: 0.75rem;
    font-weight: 600;
    color: var(--text-faint);
    letter-spacing: 0.08em;
    text-transform: uppercase;
    margin-bottom: 0.75rem;
  }

  .what-to-try ul {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .what-to-try li {
    font-family: var(--font-mono);
    font-size: 0.825rem;
    color: var(--text-muted);
    padding: 0.5rem 0.75rem;
    background: var(--bg-elevated);
    border-radius: var(--radius-sm);
    border: 1px solid var(--border);
  }
  .what-to-try li::before { content: '›'; color: var(--accent); margin-right: 0.5rem; }

  .launch-btn {
    display: flex;
    align-items: center;
    gap: 0.625rem;
    padding: 1rem 1.5rem;
    background: var(--accent);
    color: #fff;
    border-radius: var(--radius-lg);
    font-size: 1rem;
    font-weight: 600;
    text-decoration: none;
    transition: background 0.15s;
  }
  .launch-btn:hover { background: var(--accent-dim); text-decoration: none; }

  .launch-hint {
    margin-left: auto;
    font-size: 0.75rem;
    opacity: 0.65;
    font-weight: 400;
  }

  /* ── Config panel ─────────────────────────────────────────────── */
  .config-panel {
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    background: var(--bg-surface);
    overflow: hidden;
    height: 100%;
  }

  .config-panel-header {
    display: flex;
    align-items: center;
    gap: 0.375rem;
    padding: 0.75rem 1rem;
    background: var(--bg-elevated);
    border-bottom: 1px solid var(--border);
  }

  .dot { width: 10px; height: 10px; border-radius: 50%; }
  .dot.r { background: #ff5f57; }
  .dot.a { background: #ffbd2e; }
  .dot.g { background: #28ca41; }

  .config-panel-filename {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: var(--text-muted);
    margin-left: 0.5rem;
  }

  .config-panel-badge {
    margin-left: auto;
    font-size: 0.7rem;
    color: var(--accent);
    background: var(--accent-subtle);
    border: 1px solid rgba(99,102,241,0.2);
    border-radius: 100px;
    padding: 0.15rem 0.5rem;
  }

  .config-panel-body {
    margin: 0;
    padding: 1.25rem 1.5rem;
    background: transparent;
    border: none;
    border-radius: 0;
    font-size: 0.8rem;
    line-height: 1.75;
    overflow-x: auto;
    color: var(--text-muted);
  }

  /* ── What the demo shows ──────────────────────────────────────── */
  .section { margin-bottom: 4rem; }
  .section h2 { color: var(--text); margin-bottom: 1.5rem; }

  .show-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1.25rem;
  }

  .show-item {
    display: flex;
    gap: 1rem;
    padding: 1.25rem;
    background: var(--bg-surface);
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    align-items: flex-start;
  }

  .show-icon {
    flex-shrink: 0;
    width: 36px;
    height: 36px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--accent-subtle);
    border: 1px solid rgba(99,102,241,0.2);
    border-radius: var(--radius);
    color: var(--accent);
  }

  .show-item h4 { color: var(--text); margin-bottom: 0.375rem; }
  .show-item p  { font-size: 0.875rem; color: var(--text-muted); line-height: 1.6; margin: 0; }

  /* ── Deploy section ───────────────────────────────────────────── */
  .deploy-section { margin-bottom: 0; }

  .deploy-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 2rem;
    padding: 2rem 2.5rem;
    background: var(--bg-surface);
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
  }

  .deploy-inner h2 { margin: 0 0 0.25rem; color: var(--text); }
  .deploy-inner p  { margin: 0; font-size: 0.9rem; color: var(--text-muted); }

  .btn-outline {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    padding: 0.625rem 1.25rem;
    border: 1px solid var(--border);
    border-radius: var(--radius);
    color: var(--text);
    font-size: 0.875rem;
    font-weight: 500;
    text-decoration: none;
    white-space: nowrap;
    transition: border-color 0.15s, color 0.15s;
    flex-shrink: 0;
  }
  .btn-outline:hover { border-color: var(--accent); color: var(--accent); text-decoration: none; }

  @media (max-width: 900px) {
    .demo-hero  { grid-template-columns: 1fr; }
    .show-grid  { grid-template-columns: 1fr; }
    .deploy-inner { flex-direction: column; align-items: flex-start; }
  }
</style>
