# Copy this file to .env and fill in your keys before running docker compose.

ANTHROPIC_API_KEY=sk-ant-...
VOYAGE_API_KEY=pa-...

# Used locally (docker-compose overrides this to point at the db service)
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/configent

# Set to 1 to reload client YAML configs on every API request (dev only)
DEV_CONFIG_RELOAD=0

# Set to 1 to run integration tests that hit the real Anthropic API
RUN_INTEGRATION=0
